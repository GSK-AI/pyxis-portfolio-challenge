# .env.example
# Backend URL for the Pyxis Portal (if applicable)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Backend URL for the Investment Game API
NEXT_PUBLIC_BACKEND_URL_GAME=http://localhost:8000

# Enable single-player mode (default: disabled)
NEXT_PUBLIC_ENABLE_SINGLE_PLAYER=false

# Azure AD authentication (leave empty for local development without auth)
NEXT_PUBLIC_AZURE_CLIENT_ID=
NEXT_PUBLIC_AZURE_AUTHORITY=
